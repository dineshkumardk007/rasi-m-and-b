# ─── Rasi Mom & Baby — environment variables ───────────────────────────────
# Copy to .env.local and fill in. The app REFUSES to start with missing keys.
# Never commit .env.local.

# Supabase (required from Phase 0) — dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Razorpay (required from Phase 2) — dashboard → Settings → API Keys
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# n8n automation (required from Phase 4)
# N8N_WEBHOOK_URL=
# N8N_WEBHOOK_SECRET=

# Analytics (optional until launch)
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
